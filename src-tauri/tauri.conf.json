{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown",
  "version": "0.1.0",
  "identifier": "com.fippli.markdown",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown",
        "width": 900,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "decorations": true,
        "resizable": true,
        "center": true,
        "titleBarStyle": "Visible",
        "backgroundColor": "#FAFAFF"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "A beautiful markdown editor for Linux",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Path to a .md file to open"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Office",
    "shortDescription": "Markdown editor",
    "longDescription": "A beautiful, keyboard-driven markdown editor for Linux."
  }
}
