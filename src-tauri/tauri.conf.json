{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown Editor",
  "version": "0.2.3",
  "identifier": "software.krill.markdown-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Editor",
        "width": 1296,
        "height": 800,
        "minWidth": 720,
        "minHeight": 445,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#FAFAFF"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "A beautiful markdown editor for Linux",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Path to a .md file to open"
        }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3Nzg5QTc4MEExOTM4MjIKUldRaU9Ca0tlSnA0aDQzcXJLRWtKWTI0K0lDM3IwTW4wcGUzdFZ5RE01ckYraU5nL1FRZWRXRmgK",
      "endpoints": [
        "https://github.com/krill-software/markdown-editor/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Markdown editor",
    "longDescription": "A beautiful, keyboard-driven markdown editor for Linux. Bundled Hasklig, Charter, and Inter fonts; math via KaTeX; diagrams via Mermaid.",
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "section": "editors",
        "priority": "optional",
        "desktopTemplate": "main.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
